<?xml version="1.0" encoding="utf-8"?>
<StretchedLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activityforgotpassword"
    android:orientation="vertical"
    android:background="#DBF5FF"
    android:gravity="center">
  <androidx.cardview.widget.CardView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:id="@+id/white_block"
      android:layout_margin="30dp"
      app:cardCornerRadius="30dp"
      app:cardElevation="20dp"
      android:background="@color/white" >
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center_horizontal"
        android:padding="24dp"
        tools:ignore="UselessLeaf">

      <TextView
          android:id="@+id/Forgot_password_head"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:fontFamily="@font/righteous"
          android:text="Forgot Password ?"
          android:textStyle="bold"
          android:textAlignment="center"
          android:textColor="#289DCC"
          android:textSize="34sp"
          tools:ignore="HardcodedText" />
      <TextView
          android:id="@+id/Forgot_password_text"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:fontFamily="@font/righteous"
          android:text="Enter email to get details !"
          android:textAlignment="center"
          android:textColor="@color/black"
          android:textSize="25sp"
          android:layout_marginTop="18dp"
          tools:ignore="HardcodedText" />
      <EditText
          android:layout_width="match_parent"
          android:layout_height="50dp"
          android:id="@+id/email_forgot_password"
          android:background="@drawable/detail_box"
          android:drawableLeft="@drawable/baseline_email_24"
          android:importantForAutofill="no"
          android:padding="15dp"
          android:drawablePadding="8dp"
          android:hint="Registered Email"
          android:fontFamily="@font/righteous"
          android:textColor="@color/black"
          android:textColorHighlight="@color/cardview_dark_background"
          android:layout_marginTop="55dp"
          tools:ignore="HardcodedText,RtlHardcoded,TextFields" />

      <Button
          android:layout_width="match_parent"
          android:layout_height="60dp"
          android:id="@+id/Forgot_password_button"
          android:backgroundTint="@color/bluish_logo"
          android:text="@string/get_details_on_email"
          android:textStyle="bold"
          android:textSize="19sp"
          android:fontFamily="@font/righteous"
          android:layout_marginTop="60dp"/>
    </LinearLayout>
  </androidx.cardview.widget.CardView>

  </StretchedLayout>
<?xml version="1.0" encoding="utf-8"?>
<StretchedLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".health_status"
    android:background="#DBF5FF">
    <TextView
        android:id="@+id/health_status_title"
        android:layout_width="500dp"
        android:layout_height="70dp"
        android:paddingLeft="50dp"
        android:paddingTop="13dp"
        android:background="@color/bluish_logo"
        android:fontFamily="@font/righteous"
        android:text="Device Health status"
        android:textColor="@color/black"
        android:textSize="34sp"
        android:textStyle="bold" />

    <ImageButton
        android:id="@+id/back_button_health_status"
        android:layout_width="50dp"
        android:layout_height="60dp"
        android:layout_marginTop="4dp"
        android:paddingLeft="10dp"
        android:backgroundTint="@color/bluish_logo"
        android:src="@drawable/baseline_arrow_back_ios_new_24"/>
    <HorizontalScrollView
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginTop="90dp"
        android:layout_marginBottom="150dp">
        <TableLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:stretchColumns="1,1,1,1,1,1"
            android:background="@drawable/table"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"
            android:layout_marginLeft="14dp"
            android:layout_marginRight="14dp">
            <TableRow>
                <TextView
                    android:id="@+id/device_status"
                    android:layout_width="90sp"
                    android:layout_column="1"
                    android:background="@drawable/table"
                    android:fontFamily="@font/righteous"
                    android:gravity="center"
                    android:padding="5dp"
                    android:text="Status"
                    android:textColor="@color/black"
                    android:textSize="18dp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/device_code"
                    android:layout_width="120sp"
                    android:layout_column="1"
                    android:background="@drawable/table"
                    android:fontFamily="@font/righteous"
                    android:gravity="center"
                    android:padding="5dp"
                    android:text="Device-code"
                    android:textColor="@color/black"
                    android:textSize="18dp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/device_controller"
                    android:layout_width="100sp"
                    android:layout_column="1"
                    android:background="@drawable/table"
                    android:fontFamily="@font/righteous"
                    android:gravity="center"
                    android:padding="5dp"
                    android:text="Controller"
                    android:textColor="@color/black"
                    android:textSize="18dp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/device_Last_heart_beat"
                    android:layout_width="140sp"
                    android:background="@drawable/table"
                    android:fontFamily="@font/righteous"
                    android:foregroundGravity="center_horizontal"
                    android:padding="5dp"
                    android:text="Last Heartbeat"
                    android:textColor="@color/black"
                    android:textSize="18dp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/device_Uptime"
                    android:layout_width="160sp"
                    android:background="@drawable/table"
                    android:fontFamily="@font/righteous"
                    android:gravity="center"
                    android:padding="5dp"
                    android:text="Uptime"
                    android:textColor="@color/black"
                    android:textSize="18dp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/device_state"
                    android:layout_width="100sp"
                    android:background="@drawable/table"
                    android:fontFamily="@font/righteous"
                    android:foregroundGravity="center_horizontal"
                    android:padding="5dp"
                    android:text="State"
                    android:textColor="@color/black"
                    android:textSize="18dp"
                    android:textStyle="bold" />

            </TableRow>
        </TableLayout>
    </HorizontalScrollView>


</StretchedLayout>
<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".user_profile"
    android:background="#DBF5FF">
    <TextView
        android:id="@+id/user_profile_title"
        android:layout_width="500dp"
        android:layout_height="70dp"
        android:paddingLeft="60dp"
        android:paddingTop="13dp"
        android:background="@color/bluish_logo"
        android:fontFamily="@font/righteous"
        android:text="User Profile"
        android:textColor="@color/black"
        android:textSize="34sp"
        android:textStyle="bold" />

    <ImageButton
        android:id="@+id/back_button_user_profile"
        android:layout_width="50dp"
        android:layout_height="60dp"
        android:layout_marginTop="4dp"
        android:paddingLeft="10dp"
        android:backgroundTint="@color/bluish_logo"
        android:src="@drawable/baseline_arrow_back_ios_new_24"/>
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/user_profile_title"
        android:layout_margin="20dp"
        android:columnCount="1"
        android:rowCount="4">
        <androidx.cardview.widget.CardView
            android:id="@+id/card_user_role_assign"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:layout_row="0"
            android:layout_column="0"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_gravity="fill"
            app:cardBackgroundColor="@color/icon_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="8dp"
            app:cardUseCompatPadding="true">

            <RelativeLayout
                android:layout_width="121dp"
                android:layout_height="80dp"
                android:layout_gravity="clip_horizontal"
                android:orientation="horizontal"/>

            <ImageView
                android:layout_width="80dp"
                android:layout_height="70dp"
               android:layout_marginLeft="18dp"
                android:layout_marginTop="4dp"
                android:src="@drawable/user_role_assign" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="User role assign"
                android:fontFamily="@font/righteous"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="25dp"
                android:layout_marginRight="60dp"
                android:layout_marginTop="22dp"/>

        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:id="@+id/card_user_page_edit_view"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:layout_row="1"
            android:layout_column="0"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_gravity="fill"
            app:cardBackgroundColor="@color/icon_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="8dp"
            app:cardUseCompatPadding="true">

            <RelativeLayout
                android:layout_width="121dp"
                android:layout_height="80dp"
                android:layout_gravity="clip_horizontal"
                android:orientation="horizontal"/>

            <ImageView
                android:layout_width="80dp"
                android:layout_height="70dp"
                android:layout_marginLeft="18dp"
                android:layout_marginTop="4dp"
                android:src="@drawable/user_page_edit_view" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="User page edit / view"
                android:fontFamily="@font/righteous"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="25dp"
                android:layout_marginRight="25dp"
                android:layout_marginTop="22dp"/>

        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:id="@+id/password_reset"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:layout_row="2"
            android:layout_column="0"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_gravity="fill"
            app:cardBackgroundColor="@color/icon_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="8dp"
            app:cardUseCompatPadding="true">

            <RelativeLayout
                android:layout_width="121dp"
                android:layout_height="80dp"
                android:layout_gravity="clip_horizontal"
                android:orientation="horizontal"/>

            <ImageView
                android:layout_width="80dp"
                android:layout_height="70dp"
                android:layout_marginLeft="18dp"
                android:layout_marginTop="4dp"
                android:src="@drawable/password_reset" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="Password reset"
                android:fontFamily="@font/righteous"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="25dp"
                android:layout_marginRight="65dp"
                android:layout_marginTop="22dp"/>

        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:id="@+id/sign_out"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:layout_column="0"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_gravity="fill"
            app:cardBackgroundColor="@color/icon_bg"
            app:cardCornerRadius="8dp"
            app:cardElevation="8dp"
            app:cardUseCompatPadding="true">

            <RelativeLayout
                android:layout_width="121dp"
                android:layout_height="80dp"
                android:layout_gravity="clip_horizontal"
                android:orientation="horizontal"/>

            <ImageView
                android:layout_width="80dp"
                android:layout_height="70dp"
                android:layout_marginLeft="18dp"
                android:layout_marginTop="4dp"
                android:src="@drawable/signout" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="Sign Out"
                android:fontFamily="@font/righteous"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="25dp"
                android:layout_marginRight="110dp"
                android:layout_marginTop="22dp"/>

        </androidx.cardview.widget.CardView>

    </GridLayout>



</RelativeLayout>
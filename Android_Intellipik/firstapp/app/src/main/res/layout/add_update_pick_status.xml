<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:layout_width="308dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp"
        tools:ignore="UselessLeaf">

        <TextView
            android:id="@+id/welcome_head"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/righteous"
            android:text="Add Pick status for new Item"
            android:textAlignment="center"
            android:textColor="@color/pop_box_text"
            android:textSize="26sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />

        <EditText
            android:id="@+id/pickstatus_code"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="30dp"
            android:background="@drawable/pop_box"
            android:drawablePadding="8dp"
            android:fontFamily="@font/righteous"
            android:hint="Order Code"
            android:importantForAutofill="no"
            android:inputType="number"
            android:padding="15dp"
            android:textColor="@color/black"
            android:textColorHighlight="@color/cardview_dark_background"
            tools:ignore="HardcodedText,RtlHardcoded,TextFields" />

        <EditText
            android:id="@+id/pickstatus_date"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/pop_box"
            android:drawablePadding="8dp"
            android:fontFamily="@font/righteous"
            android:hint="Order Date (DD/MM/YYYY)"
            android:importantForAutofill="no"
            android:padding="15dp"
            android:focusable="true"
            android:clickable="true"
            android:textColor="@color/black"
            android:textColorHighlight="@color/cardview_dark_background"
            tools:ignore="HardcodedText,RtlHardcoded" />

        <EditText
            android:id="@+id/pickstatus_name"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/pop_box"
            android:drawablePadding="8dp"
            android:fontFamily="@font/righteous"
            android:hint="Picklist Name"
            android:importantForAutofill="no"
            android:inputType="text"
            android:padding="15dp"
            android:textColor="@color/black"
            android:textColorHighlight="@color/cardview_dark_background"
            tools:ignore="HardcodedText,RtlHardcoded" />

        <EditText
            android:id="@+id/pickstatus_number_kits"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/pop_box"
            android:drawablePadding="8dp"
            android:fontFamily="@font/righteous"
            android:hint="No. of kits"
            android:importantForAutofill="no"
            android:inputType="number"
            android:padding="15dp"
            android:textColor="@color/black"
            android:textColorHighlight="@color/cardview_dark_background"
            tools:ignore="HardcodedText,RtlHardcoded" />

        <EditText
            android:id="@+id/pickstatus_number_kits_picked"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/pop_box"
            android:drawablePadding="8dp"
            android:fontFamily="@font/righteous"
            android:hint="No. of kits picked"
            android:importantForAutofill="no"
            android:inputType="number"
            android:padding="15dp"
            android:textColor="@color/black"
            android:textColorHighlight="@color/cardview_dark_background"
            tools:ignore="HardcodedText,RtlHardcoded" />

        <EditText
            android:id="@+id/pickstatus_status"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/pop_box"
            android:drawablePadding="8dp"
            android:fontFamily="@font/righteous"
            android:hint="status"
            android:importantForAutofill="no"
            android:inputType="text"
            android:padding="15dp"
            android:textColor="@color/black"
            android:textColorHighlight="@color/cardview_dark_background"
            tools:ignore="HardcodedText,RtlHardcoded" />

        <Button
            android:id="@+id/add_button"
            android:layout_width="100dp"
            android:layout_height="60dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="30dp"
            android:backgroundTint="@color/pop_box_text"
            android:fontFamily="@font/righteous"
            android:text="Add"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>